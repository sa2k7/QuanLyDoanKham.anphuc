
<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<style>
  table { border-collapse: collapse; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; margin-bottom: 30px; }
  .summary-table th { background-color: #f59e0b; color: #000; padding: 12px; border: 2px solid #000; font-size: 15px; }
  .summary-table td { padding: 15px; border: 1px solid #000; font-size: 16px; text-align: center; font-weight: bold; }
  .detail-table th { background-color: #0f172a; color: #fff; padding: 12px 8px; border: 1px solid #000; font-size: 11px; text-transform: uppercase; }
  .detail-table td { padding: 10px 8px; border: 1px solid #cbd5e1; font-size: 11px; vertical-align: top; }
  .passed { color: #15803d; font-weight: bold; background-color: #dcfce7; text-align: center; }
  .high { color: #b91c1c; font-weight: bold; }
  .id-col { background-color: #f8fafc; font-weight: bold; text-align: center; color: #475569; }
</style>
</head>
<body>

<table class="summary-table" style="width: 500px;">
  <thead>
    <tr><th colspan="3">Báo cáo Kiểm thử Tổng hợp (Giai đoạn 1 & 2)</th></tr>
    <tr style="background:#fff;"><td>Tổng trường hợp</td><td>Đã đạt (Passed)</td><td>Lỗi (Failed)</td></tr>
  </thead>
  <tbody>
    <tr><td>16</td><td style="color:#15803d;">16</td><td style="color:#b91c1c;">0</td></tr>
  </tbody>
</table>



<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<style>
  table { border-collapse: collapse; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; margin-bottom: 30px; }
  
  /* Bảng tóm tắt màu cam */
  .summary-table th { background-color: #f59e0b; color: #000000; padding: 12px; border: 2px solid #000000; font-size: 15px; text-align: left; }
  .summary-table td { padding: 15px; border: 1px solid #000000; font-size: 16px; text-align: center; font-weight: bold; }
  
  /* Bảng chi tiết 12 cột */
  .detail-table th { background-color: #0f172a; color: #ffffff; padding: 15px 8px; border: 1px solid #000000; font-size: 12px; text-transform: uppercase; }
  .detail-table td { padding: 10px 8px; border: 1px solid #cbd5e1; font-size: 12px; vertical-align: top; line-height: 1.4; }
  
  .passed { color: #15803d; font-weight: bold; background-color: #f0fdf4; text-align: center; }
  .failed { color: #b91c1c; font-weight: bold; background-color: #fef2f2; text-align: center; }
  .id-col { background-color: #f8fafc; font-weight: bold; text-align: center; color: #475569; }
</style>
</head>
<body>

<!-- BẢNG TỔNG HỢP (MẪU CAM) -->
<table class="summary-table" style="width: 500px;">
  <thead>
    <tr>
      <th colspan="3">Kết quả kiểm thử thủ công</th>
    </tr>
    <tr>
      <td style="background-color: #ffffff; text-align: left;">Trường hợp kiểm thử</td>
      <td style="background-color: #ffffff;">Passed</td>
      <td style="background-color: #ffffff;">Failed</td>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>47</td>
      <td>19</td>
      <td>28</td>
    </tr>
  </tbody>
</table>

<br>

<!-- BẢNG CHI TIẾT 12 CỘT -->
<table class="detail-table">
  <thead>
    <tr>
      <th>Test Case ID</th>
      <th>Trường hợp kiểm thử</th>
      <th>Bước test</th>
      <th>Dữ liệu đầu vào</th>
      <th>Kết quả mong đợi</th>
      <th>Kết quả thực tế</th>
      <th>Môi trường sử dụng</th>
      <th>Trạng thái test</th>
      <th>Độ nghiêm trọng</th>
      <th>Độ ưu tiên</th>
      <th>Ghi chú</th>
      <th>Hình ảnh</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="id-col">TC-CON-001</td>
      <td><b>Khóa/Mở khóa hợp đồng</b></td>
      <td>1. Mở HĐ Active<br>2. Bấm Khóa<br>3. Kiểm tra nút sửa</td>
      <td>HealthContractId: 1</td>
      <td>Nút sửa biến mất, trạng thái thành Locked</td>
      <td>Đã sửa lỗi: Hiện nút sửa ẩn khi khóa</td>
      <td>Local / Chrome</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">High</td>
      <td>Admin mới được mở khóa</td>
      <td></td>
    </tr>
    <tr>
      <td class="id-col">TC-COM-001</td>
      <td><b>Chống trùng MST Công ty</b></td>
      <td>1. Tạo công ty mới<br>2. Nhập MST đã tồn tại</td>
      <td>TaxCode: 0101234567</td>
      <td>Hiện cảnh báo trùng, không cho lưu</td>
      <td>Đã sửa lỗi: Trước đó cho lưu trùng</td>
      <td>Local / Chrome</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">High</td>
      <td>Kiểm tra cả Backend/Frontend</td>
      <td></td>
    </tr>
    <tr>
      <td class="id-col">TC-STF-001</td>
      <td><b>Lưu nhân sự không bị lag</b></td>
      <td>1. Sửa thông tin nhân sự<br>2. Bấm Lưu</td>
      <td>Staff: Nguyễn Văn A</td>
      <td>Dữ liệu cập nhật ngay, không hiện đỏ</td>
      <td>Đã sửa lỗi: "Hiện đỏ rồi mới cập nhật"</td>
      <td>Local / Chrome</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">Medium</td>
      <td style="text-align:center">High</td>
      <td>Đã xử lý Async/Await</td>
      <td></td>
    </tr>
    <tr>
      <td class="id-col">TC-SUP-001</td>
      <td><b>Trừ kho khi xuất vật tư</b></td>
      <td>1. Tạo phiếu xuất kho<br>2. Kiểm tra tồn thực tế</td>
      <td>Số lượng: 10</td>
      <td>Tồn kho giảm đúng 10 đơn vị</td>
      <td>Đã sửa lỗi: Xuất nhưng không trừ kho</td>
      <td>Local / Chrome</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">High</td>
      <td>Check trigger DB</td>
      <td></td>
    </tr>
    <tr>
      <td class="id-col">TC-I18N-001</td>
      <td><b>Chuyển ngữ Dashboard</b></td>
      <td>1. Click nút chuyển EN</td>
      <td>Locale: EN</td>
      <td>Menu chuyển sang English ngay lập tức</td>
      <td>Đã sửa lỗi: Một số menu không đổi</td>
      <td>Local / Chrome</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">Low</td>
      <td style="text-align:center">Medium</td>
      <td>Sử dụng Pinia i18n store</td>
      <td></td>
    </tr>
  </tbody>
</table>
</body>
</html>

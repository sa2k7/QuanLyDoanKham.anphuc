<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<style>
  table { border-collapse: collapse; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; margin-bottom: 30px; }
  .summary-table th { background-color: #3b82f6; color: #fff; padding: 12px; border: 2px solid #000; font-size: 15px; }
  .summary-table td { padding: 15px; border: 1px solid #000; font-size: 16px; text-align: center; font-weight: bold; }
  .detail-table th { background-color: #1e293b; color: #fff; padding: 12px 8px; border: 1px solid #000; font-size: 11px; text-transform: uppercase; }
  .detail-table td { padding: 10px 8px; border: 1px solid #cbd5e1; font-size: 11px; vertical-align: top; }
  .passed { color: #15803d; font-weight: bold; background-color: #dcfce7; text-align: center; }
  .fixed { color: #2563eb; font-weight: bold; background-color: #dbeafe; text-align: center; }
  .high { color: #b91c1c; font-weight: bold; }
  .id-col { background-color: #f8fafc; font-weight: bold; text-align: center; color: #475569; }
</style>
</head>
<body>

<table class="summary-table" style="width: 600px;">
  <thead>
    <tr><th colspan="4">Báo cáo Kiểm thử & Nhật ký Fix Lỗi (Giai đoạn Hiện tại)</th></tr>
    <tr style="background:#fff;">
      <td>Tổng số lỗi phát hiện</td>
      <td>Đã xử lý (Fixed)</td>
      <td>Đang kiểm tra (Checking)</td>
      <td>Tỷ lệ hoàn thành</td>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>10</td>
      <td style="color:#15803d;">10</td>
      <td style="color:#f59e0b;">0</td>
      <td style="color:#2563eb;">100%</td>
    </tr>
  </tbody>
</table>

<table class="detail-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Trường hợp kiểm thử / Lỗi</th>
      <th>Bước tái hiện</th>
      <th>Dữ liệu đầu vào</th>
      <th>Kết quả mong đợi</th>
      <th>Nhật ký Fix & Kết quả thực tế</th>
      <th>Môi trường</th>
      <th>Trạng thái</th>
      <th>Độ nghiêm trọng</th>
      <th>Độ ưu tiên</th>
      <th>Ghi chú chuyên sâu</th>
    </tr>
  </thead>
  <tbody>
    
    <tr>
      <td class="id-col">TC-SEC-001</td>
      <td><b>Đồng bộ mật khẩu Admin sau Deploy</b></td>
      <td>Khởi động lại hệ thống và đăng nhập</td>
      <td>admin123 / Seed Data</td>
      <td>Mật khẩu luôn cố định và truy cập được</td>
      <td><b>Fixed:</b> Thay Hash động bằng Hash tĩnh. Thêm hầm ngầm CLI khôi phục khẩn cấp.</td>
      <td>SmarterASP / Local</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">Critical</td>
      <td style="text-align:center"><span class="high">P0</span></td>
      <td>Đã bảo mật lại CSDL</td>
    </tr>

    <tr>
      <td class="id-col">TC-UI-001</td>
      <td><b>Lỗi Vercel Crash trang Hợp đồng</b></td>
      <td>Mở trang /contracts trên bản live</td>
      <td>Render View</td>
      <td>Hiển thị bảng danh sách hợp đồng</td>
      <td><b>Fixed:</b> Đồng bộ tên hàm getStatusLabel trong Template và Script setup.</td>
      <td>Vercel Production</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center"><span class="high">P1</span></td>
      <td>Tránh trắng màn hình</td>
    </tr>

    <tr>
      <td class="id-col">TC-AUTH-004</td>
      <td><b>Truy cập trang bị đẩy ra (403 Forbidden)</b></td>
      <td>Vào trang Contracts bằng quyền Admin</td>
      <td>Role Admin (RoleId=1)</td>
      <td>Vào trang bình thường</td>
      <td><b>Fixed:</b> Khôi phục tính toàn vẹn Claims của Role Admin trong DB thực tế.</td>
      <td>Local / Chrome</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center"><span class="high">P1</span></td>
      <td>Audit integrity thành công</td>
    </tr>

    <tr>
      <td class="id-col">TC-UI-002</td>
      <td><b>Phù hợp phong cách Giao diện (UI UX)</b></td>
      <td>Kiểm tra toàn bộ hệ thống</td>
      <td>Design Language</td>
      <td>Chuẩn Pro Max (Tinh tế, Minimalist)</td>
      <td><b>Fixed:</b> Loại bỏ phong cách Brutalism thô ráp, áp dụng Glassmorphism.</td>
      <td>Local / Web</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">Medium</td>
      <td style="text-align:center">Medium</td>
      <td>Đã duyệt lại Layout</td>
    </tr>

    <tr>
      <td class="id-col">TC-INT-002</td>
      <td><b>Mapping DTO thuộc tính Hợp đồng</b></td>
      <td>Xem chi tiết hợp đồng</td>
      <td>HealthContractId</td>
      <td>Hiển thị đúng mã hợp đồng</td>
      <td><b>Fixed:</b> Đồng bộ contractId -> healthContractId giữa Frontend và Backend.</td>
      <td>API / SQL</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">P1</td>
      <td>Dữ liệu đã hiện đúng</td>
    </tr>

    <tr>
      <td class="id-col">TC-API-001</td>
      <td><b>API 404 Endpoint Groups</b></td>
      <td>Tải danh sách nhóm khám</td>
      <td>GET /api/groups</td>
      <td>Trả về mảng 200 OK</td>
      <td><b>Fixed:</b> Sửa Route Controller từ /api/medicalgroups thành /api/groups.</td>
      <td>SmarterASP</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">Medium</td>
      <td style="text-align:center">P2</td>
      <td>Đã thông endpoint</td>
    </tr>

    <tr>
      <td class="id-col">TC-IMP-001</td>
      <td><b>Import Excel Nhân sự (Dữ liệu Null)</b></td>
      <td>Upload file Excel thiếu thông tin</td>
      <td>Excel file (.xlsx)</td>
      <td>Bỏ qua hoặc báo lỗi thân thiện</td>
      <td><b>Fixed:</b> Thêm logic xử lý Nullable Types trong service Import.</td>
      <td>Backend C#</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">P1</td>
      <td>Data ổn định</td>
    </tr>

    <tr>
      <td class="id-col">TC-UI-003</td>
      <td><b>Xử lý Style CSS khi Reload</b></td>
      <td>Refresh liên tục trang Dashboard</td>
      <td>CSS Injection</td>
      <td>Layout không bị vỡ</td>
      <td><b>Fixed:</b> Ưu tiên import main.css tại vị trí cao nhất trong main.js.</td>
      <td>Frontend Vue</td>
      <td class="passed">PASSED</td>
      <td style="text-align:center">Medium</td>
      <td style="text-align:center">P2</td>
      <td>Đã chuẩn hóa thứ tự CSS</td>
    </tr>

    <tr>
      <td class="id-col">TC-AUTH-005</td>
      <td><b>Catch lầm mã lỗi 401/400</b></td>
      <td>Nhập sai mật khẩu lúc login</td>
      <td>Wrong Credential</td>
      <td>Hiện toast báo lỗi cụ thể</td>
      <td><b>Fixed:</b> Cấu hình Axios Interceptor để bắt đúng Response Data Error.</td>
      <td>Axios Client</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">Medium</td>
      <td style="text-align:center">P2</td>
      <td>UX cải thiện</td>
    </tr>

    <tr>
      <td class="id-col">TC-DB-001</td>
      <td><b>Lỗi FK DoctorId khi tạo Hợp đồng</b></td>
      <td>Tạo mới một hợp đồng đoàn khám</td>
      <td>DB Insert</td>
      <td>Thêm bản ghi thành công</td>
      <td><b>Fixed:</b> Set mặc định Doctor phụ trách nếu không chọn, tránh lỗi khóa ngoại.</td>
      <td>SQL Server</td>
      <td class="fixed">FIXED</td>
      <td style="text-align:center">High</td>
      <td style="text-align:center">P1</td>
      <td>DB Constraint OK</td>
    </tr>

  </tbody>
</table>
</body>
</html>
